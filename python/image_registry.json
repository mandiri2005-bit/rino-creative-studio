    "atlascloud": "ATLASCLOUD_API_KEY",
    "kie": "KIE_API_KEY",
    "fal": "FAL_API_KEY",
    "aiml": "AIMLAPI_API_KEY",
    "openai": "OPENAI_API_KEY",
    "bfl": "BFL_API_KEY",
    "byteplus": "BYTEPLUS_API_KEY",
    "recraft": "RECRAFT_API_KEY",
    "vectorizer": "VECTORIZER_API_ID + VECTORIZER_API_SECRET",
