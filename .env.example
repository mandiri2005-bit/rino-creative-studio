# ── LaoZhang API (Chat · Image · Veo · Sora · Whisk · Flow)
LAOZHANG_API_KEY=paste-your-laozhang-api-key
LAOZHANG_IMAGE_API_KEY=      # optional — defaults to LAOZHANG_API_KEY if blank

# ── Gemini (Batch Images · TTS · Imagen)
GEMINI_API_KEY=paste-your-gemini-api-key

# ── MCP File Search (only needed if using --profile mcp)
MCP_FOLDER=./mcp-folder       # local folder to index
MCP_SEARCH_MODE=bm25          # bm25 | hybrid | api | local

# ── Step 4: Credit metering ────────────────────────────────────────────────
METERING_ENABLED=true          # false = disable the credit gate (no 402, no charges)
CREDIT_USD_VALUE=0.01          # USD value of 1 credit (pricing-tool basis)
CREDIT_MARGIN=1.0              # multiplier on upstream cost (1.0 = break-even)
BILLING_TOPUP_URL=/index.html#billing

# ── Step 4: Stripe billing (create products in the Stripe Dashboard) ───────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...        # from `stripe listen` or the dashboard endpoint
# Subscription price ids (price_...):
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_STUDIO=
# One-time credit-pack price ids (price_...):
STRIPE_PRICE_PACK_SMALL=
STRIPE_PRICE_PACK_MEDIUM=
STRIPE_PRICE_PACK_LARGE=
# Credits granted per pack purchase:
STRIPE_PACK_SMALL_CREDITS=1000
STRIPE_PACK_MEDIUM_CREDITS=5000
STRIPE_PACK_LARGE_CREDITS=15000
# Redirect URLs (absolute in prod, e.g. https://app.ceritai.com/index.html?billing=success):
STRIPE_CHECKOUT_SUCCESS_URL=/index.html?billing=success
STRIPE_CHECKOUT_CANCEL_URL=/index.html?billing=cancel
STRIPE_PORTAL_RETURN_URL=/index.html

# ── Dodo Payments (global / card rail, Merchant-of-Record) — PARALLEL to Stripe ──
# Dodo is the seller-of-record for non-Indonesian / card customers. Leave empty to
# disable (the app boots fine; /payments/dodo/* return dodo_not_configured).
# test_ and live_ values DIFFER per environment: keys, product ids, and the webhook
# signing secret. DODO_ENVIRONMENT MUST match the key type (mismatch = charges fail).
DODO_PAYMENTS_API_KEY=                 # test_... (test) / live_... (go-live)
DODO_PAYMENTS_WEBHOOK_SECRET=whsec_... # Dashboard → Webhooks → endpoint → signing secret
DODO_ENVIRONMENT=test_mode             # 'test_mode' | 'live_mode'
# Product ids created in the Dodo dashboard (per environment):
DODO_PRODUCT_ID_STARTER=
DODO_PRODUCT_ID_PRO=
DODO_PRODUCT_ID_STUDIO=
# Hosted-checkout return URLs. Optional — default to the same ?billing= flow as the
# Stripe rail, prefixed by APP_BASE_URL when set (absolute in prod):
APP_BASE_URL=                          # e.g. https://app.ceritai.com
DODO_CHECKOUT_RETURN_URL=
DODO_CHECKOUT_CANCEL_URL=

# ── Midtrans (IDR rail: QRIS / VA / GoPay) — PARALLEL to Stripe + Dodo ──────────
# Indonesian users pay here. Hosted Snap flow only. Leave empty to disable
# (/payments/midtrans/* return midtrans_not_configured). Sandbox vs production is
# an INDEPENDENT toggle from Dodo: keep MIDTRANS_IS_PRODUCTION=false (Sandbox) while
# testing — Snap auto-uses app.sandbox.midtrans.com. Sandbox & production keys DIFFER.
MIDTRANS_IS_PRODUCTION=false           # 'true' => production; 'false' => Sandbox
MIDTRANS_SERVER_KEY=                   # SANDBOX Server Key while testing (SB-Mid-server-...)
MIDTRANS_CLIENT_KEY=                   # SANDBOX Client Key (frontend loads snap.js with this)
# Plan price in IDR (whole rupiah). Optional — sane defaults match credit_catalog:
MIDTRANS_PRICE_STARTER=79000
MIDTRANS_PRICE_PRO=199000
MIDTRANS_PRICE_STUDIO=499000

# ── Step 4: admin manual credit grant (bootstrap, no Stripe). Empty = endpoint disabled. ──
# Set a strong random string, then: curl -X POST $URL/api/admin/grant -H "X-Admin-Secret: $ADMIN_API_SECRET" -H "Content-Type: application/json" -d '{"email":"user@example.com","credits":5000}'
ADMIN_API_SECRET=

# ── Step 6: video assembly engine (BullMQ workers + FFmpeg stitch) ──
# Trusted server-to-server secret so the video-worker authenticates to the Python
# API as the tenant (per-scene metering + RLS). MUST be a strong random string and
# kept server-only (never exposed to the browser). Empty = internal auth disabled.
INTERNAL_SERVICE_SECRET=
# Where the audio worker fetches per-scene narration (Python single-shot TTS route).
VIDEO_TTS_AUDIO_PATH=/video/tts/scene
# Output encode defaults (the worker stitches at these). Lower them for cheaper tests.
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=30
VIDEO_PRESET=medium
# Set to 1 to run the worker with the synthetic generator (no API keys) for a demo.
VIDEO_SYNTHETIC=
# Auto-delete finished videos from R2 (under the videos/ prefix) after N days.
VIDEO_R2_TTL_DAYS=7
