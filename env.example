# ═══════════════════════════════════════════════════════════════════════════════
# rino-saas  ·  Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#   cp .env.example .env        ← copy once, then fill in real values
#   NEVER commit .env to git — only .env.example is tracked
# ═══════════════════════════════════════════════════════════════════════════════

# ── General ─────────────────────────────────────────────────────────────────
NODE_ENV=development                     # development | staging | production

# ═══════════════════════════════════════════════════════════════════════════════
# AI / LLM API Keys
# ═══════════════════════════════════════════════════════════════════════════════
GEMINI_API_KEY=
LAOZHANG_API_KEY=
LAOZHANG_IMAGE_API_KEY=
DEEPSEEK_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# MCP File Search  (only used when --profile mcp is active)
# ═══════════════════════════════════════════════════════════════════════════════
MCP_FOLDER=/path/to/your/mcp-folder      # e.g. /Users/rino/Documents/rino-creative-studio
MCP_SEARCH_MODE=bm25                     # bm25 | semantic

