# ═══════════════════════════════════════════════════════════════════════════════
# Redis  —  cancel flags, job queues  (Phase WS2)
# ═══════════════════════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL="https://enormous-katydid-40938.upstash.io" 
UPSTASH_REDIS_REST_TOKEN="<pass>"


# ═══════════════════════════════════════════════════════════════════════════════
# Object Storage — S3 / Cloudflare R2  (Phase WS3)
# Replaces local volume mounts for veo, sora, tts, imgs, batch outputs
# ═══════════════════════════════════════════════════════════════════════════════
STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
STORAGE_BUCKET=rino-saas-assets
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=auto                      # "auto" for R2; us-east-1 etc. for AWS S3
STORAGE_PUBLIC_URL=                      # optional CDN / public URL for serving assets

# ═══════════════════════════════════════════════════════════════════════════════
# Video-worker CPU tuning — FFmpeg oversubscription guard
# Sizing rule: (VIDEO_THREADS + VIDEO_FILTER_THREADS) × FFMPEG_ENCODER_SLOTS ≈ vCPU.
# Defaults below = 2 × (2 + 2) = 8, sized for the 8-vCPU worker (no oversubscription).
# ESCAPE HATCH (revert to pre-fix behaviour — set these + restart, no rebuild):
#   FFMPEG_ENCODER_SLOTS=0  VIDEO_THREADS=0  VIDEO_FILTER_THREADS=0  VIDEO_PRESET=medium  GEN_FETCH_TIMEOUT_MS=0
# ═══════════════════════════════════════════════════════════════════════════════
FFMPEG_ENCODER_SLOTS=2                    # max concurrent ffmpeg ENCODES on this box (0 = unlimited)
VIDEO_THREADS=2                          # libx264 codec threads per encode (0 = ffmpeg default = all cores)
VIDEO_FILTER_THREADS=2                   # filtergraph threads per encode — zoompan/xfade pool (0 = default)
VIDEO_PRESET=veryfast                    # x264 preset; "medium" = pre-fix quality/size
GEN_FETCH_TIMEOUT_MS=120000              # per-request timeout for TTS/image/Recraft fetches (0 = none)
# Left as-is — the encoder semaphore now caps their cross-product:
# VIDEO_RENDER_CONCURRENCY=4   VIDEO_STITCH_CONCURRENCY=2
