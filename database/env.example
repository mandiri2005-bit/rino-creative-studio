# ═══════════════════════════════════════════════════════════════════════════════
# rino-saas  ·  Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#   cp .env.example .env        ← copy once, then fill in real values
#   NEVER commit .env to git — only .env.example is tracked
# ═══════════════════════════════════════════════════════════════════════════════

# ── General ─────────────────────────────────────────────────────────────────
NODE_ENV=development                     # development | staging | production

# ═══════════════════════════════════════════════════════════════════════════════
# AI / LLM API Keys
# ═══════════════════════════════════════════════════════════════════════════════
GEMINI_API_KEY=
LAOZHANG_API_KEY=
LAOZHANG_IMAGE_API_KEY=
DEEPSEEK_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# MCP File Search  (only used when --profile mcp is active)
# ═══════════════════════════════════════════════════════════════════════════════
MCP_FOLDER=/path/to/your/mcp-folder      # e.g. /Users/rino/Documents/rino-creative-studio
MCP_SEARCH_MODE=bm25                     # bm25 | semantic

# ═══════════════════════════════════════════════════════════════════════════════
# Neon PostgreSQL  —  rino-saas project
# ═══════════════════════════════════════════════════════════════════════════════

# MAIN branch (production)  ──────────────────────────────────────────────────
DATABASE_URL=postgresql://neondb_owner:<password>@ep-proud-truth-aqg5hqu4.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_POOL_URL=postgresql://neondb_owner:<password>@ep-proud-truth-aqg5hqu4-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# DEVELOP branch  ────────────────────────────────────────────────────────────
DATABASE_URL_DEV=postgresql://neondb_owner:<password>@ep-broad-salad-aq5i4iiu.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_POOL_URL_DEV=postgresql://neondb_owner:<password>@ep-broad-salad-aq5i4iiu-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# STAGING branch  ────────────────────────────────────────────────────────────
DATABASE_URL_STAGING=postgresql://neondb_owner:<password>@ep-misty-haze-aqkyujcb.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_POOL_URL_STAGING=postgresql://neondb_owner:<password>@ep-misty-haze-aqkyujcb-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ═══════════════════════════════════════════════════════════════════════════════
# Auth — Clerk  (Phase WS2)
# ═══════════════════════════════════════════════════════════════════════════════
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════════════════════════
# Redis  —  cancel flags, job queues  (Phase WS2)
# ═══════════════════════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════════════════════════════════════════
# Object Storage — S3 / Cloudflare R2  (Phase WS3)
# Replaces local volume mounts for veo, sora, tts, imgs, batch outputs
# ═══════════════════════════════════════════════════════════════════════════════
STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
STORAGE_BUCKET=rino-saas-assets
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=auto                      # "auto" for R2; us-east-1 etc. for AWS S3
STORAGE_PUBLIC_URL=                      # optional CDN / public URL for serving assets
